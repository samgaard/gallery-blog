DATABASE_URL=postgresql://user:password@host:5432/dbname

NEXT_PUBLIC_SITE_NAME=Your Name

# Generate with: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-random-32-char-string

# Single admin user credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this

# Contact form
NEXT_PUBLIC_TURNSTILE_SITE_KEY=        # Cloudflare Turnstile site key (public)
TURNSTILE_SECRET_KEY=                   # Cloudflare Turnstile secret key
RESEND_API_KEY=                         # resend.com API key
CONTACT_RECIPIENT_EMAIL=               # Comma-separated recipient address(es)
CONTACT_BCC_EMAIL=                     # Optional — BCC address(es) for monitoring, invisible to sender
CONTACT_FROM_EMAIL=onboarding@resend.dev  # Dev/preview: onboarding@resend.dev; Production: contact@frankgaard.com (after DNS verification)

# Cloudflare R2 — fill in during Phase 2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=frankgaard-images
R2_PUBLIC_URL=
